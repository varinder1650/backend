# ============================================
# SmartBag Backend — Environment Variables
# ============================================
# Copy this file to .env.development and .env.production
# and fill in the actual values.
#
# Usage:
#   Dev (default):  python -m uvicorn main:app --reload
#   Prod:           APP_ENV=production python -m uvicorn main:app
# ============================================

# Environment
ENVIRONMENT=Development

# Database
MONGO_URI=mongodb+srv://user:password@cluster.mongodb.net/?retryWrites=true&w=majority
DB_NAME=smartbag
DB_CONNECTION_POOL_SIZE=10

# Redis
REDIS_URL=redis://localhost:6379/0
REDIS_MAX_CONNECTIONS=100
REDIS_SOCKET_TIMEOUT=5
REDIS_SOCKET_CONNECT_TIMEOUT=5

# JWT
SECRET_KEY=your-secret-key-here
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=15
REFRESH_TOKEN_EXPIRE_DAYS=7

# Security
ALLOWED_ORIGINS=http://localhost:3000
BCRYPT_ROUNDS=10
MAX_CART_ITEMS_PER_PRODUCT=100
ENABLE_RATE_LIMITING=true

# Email (SMTP)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
FROM_EMAIL=
FROM_NAME=SmartBag

# Ola Maps
OLA_KRUTRIM_API_KEY=
OLA_BASE_URL=https://api.olamaps.io/places/v1

# Performance
API_RATE_LIMIT_PER_MINUTE=1000
RATE_LIMIT_BURST=10
SLOW_QUERY_THRESHOLD=1.0
ENABLE_QUERY_CACHE=true
ENABLE_MULTI_LAYER_CACHE=true

# Cache TTL (seconds)
CACHE_TTL_CART=1800
CACHE_TTL_PRODUCT_DETAIL=3600
CACHE_TTL_PRODUCT_LIST=600
CACHE_TTL_CATEGORIES=7200
CACHE_TTL_BRANDS=7200
CACHE_TTL_USER_ORDERS=900
CACHE_TTL_SHOP_STATUS=300
CACHE_TTL_INVENTORY=60

# Monitoring
LOG_LEVEL=INFO
ENABLE_PROFILING=false
SENTRY_DSN=

# File Upload
MAX_FILE_SIZE=5242880
ALLOWED_IMAGE_TYPES=image/jpeg,image/png,image/webp

# Search (optional)
ELASTICSEARCH_HOST=localhost
ELASTICSEARCH_PORT=9200
ENABLE_ELASTICSEARCH=false
ELASTICSEARCH_INDEX_PREFIX=smartbag

# Background Tasks (optional)
ENABLE_CELERY=false
CELERY_BROKER_URL=redis://localhost:6379/1
CELERY_RESULT_BACKEND=redis://localhost:6379/2

# Cloudinary
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# Order
ORDER_SIGNATURE_SECRET=
